# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# IMPORTANT: For external hosting (e.g., Zeabur, Vercel), use VITE_GEMINI_API_KEY.
# Vite only exposes variables prefixed with VITE_ to the browser.
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# VITE_SURREALDB_URL: The URL of your SurrealDB instance (e.g., https://my-surreal.cloud)
VITE_SURREALDB_URL=
# VITE_SURREALDB_NS: Namespace
VITE_SURREALDB_NS=
# VITE_SURREALDB_DB: Database name
VITE_SURREALDB_DB=
# VITE_SURREALDB_USER: Username
VITE_SURREALDB_USER=
# VITE_SURREALDB_PASS: Password
VITE_SURREALDB_PASS=
